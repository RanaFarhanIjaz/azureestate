<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.azureestate">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <uses-permission android:name="android.permission.CALL_PHONE"/>

    <application
        android:enableOnBackInvokedCallback="true"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AzureEstate">

        <!-- Splash Activity (LAUNCHER) -->
        <activity
            android:name=".SplashActivity"
            android:theme="@style/Theme.AzureEstate.Splash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Activity -->
        <activity
            android:name=".LoginActivity"
            android:theme="@style/Theme.AzureEstate"
            android:exported="false" />

        <!-- Main Activity (after login) -->
        <activity
            android:name=".MainActivity"
            android:theme="@style/Theme.AzureEstate"
            android:exported="false" />

        <activity
            android:name=".SignUpActivity"
            android:theme="@style/Theme.AzureEstate"
            android:exported="false" />

        <activity
            android:name=".UploadPropertyActivity"
            android:theme="@style/Theme.AzureEstate"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <activity
            android:name=".ChatRoomActivity"
            android:theme="@style/Theme.AzureEstate"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <activity
            android:name=".LegalActivity"
            android:theme="@style/Theme.AzureEstate"
            android:exported="false"/>

        <activity
            android:name=".ContactSalesActivity"
            android:theme="@style/Theme.AzureEstate"
            android:exported="false"/>

        <activity
            android:name=".PricePredictorActivity"
            android:theme="@style/Theme.AzureEstate"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

    </application>

</manifest>