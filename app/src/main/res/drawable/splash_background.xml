<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
 
    <!-- Base dark navy color -->
    <item>
        <color android:color="#0A1929"/>
    </item>
 
    <!-- Radial-style center glow via subtle gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600"
                android:centerX="0.5"
                android:centerY="0.4"
                android:startColor="#1A3558"
                android:endColor="#00000000"/>
        </shape>
    </item>
 
</layer-list>