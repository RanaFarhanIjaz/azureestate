<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F8">

    <!-- ─── Top Bar ─── -->
    <LinearLayout
        android:id="@+id/chatTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0D1B2A"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="52dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Back -->
            <ImageView
                android:id="@+id/ivChatBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back"
                android:tint="#FFFFFF"
                android:background="@drawable/icon_btn_bg_dark"
                android:padding="9dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <!-- Other user avatar + name + status -->
            <LinearLayout
                android:id="@+id/llOtherUserInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toEndOf="@+id/ivChatBack"
                app:layout_constraintEnd_toStartOf="@+id/llChatActions"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <FrameLayout android:layout_width="38dp" android:layout_height="38dp"
                    android:layout_marginEnd="10dp">
                    <ImageView
                        android:id="@+id/ivOtherAvatar"
                        android:layout_width="38dp" android:layout_height="38dp"
                        android:src="@drawable/ic_avatar_placeholder"
                        android:scaleType="centerCrop"
                        android:background="@drawable/profile_avatar_ring"/>
                    <View
                        android:id="@+id/onlineIndicator"
                        android:layout_width="10dp" android:layout_height="10dp"
                        android:background="@drawable/status_dot_online"
                        android:layout_gravity="bottom|end"/>
                </FrameLayout>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvOtherName"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Owner Name" android:textColor="#FFFFFF"
                        android:textSize="14sp" android:fontFamily="@font/montserrat_semibold"/>
                    <TextView android:id="@+id/tvChatSubtitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Property Name" android:textColor="#8AAFC8"
                        android:textSize="11sp" android:fontFamily="@font/montserrat_regular"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Call + more actions -->
            <LinearLayout
                android:id="@+id/llChatActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Call button -->
                <ImageView
                    android:id="@+id/btnCallOwner"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/ic_call"
                    android:tint="#3DB8A8"
                    android:background="@drawable/icon_btn_bg_dark"
                    android:padding="9dp"
                    android:layout_marginEnd="8dp"/>

                <!-- More options -->
                <ImageView
                    android:id="@+id/btnChatMore"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/ic_more_vert"
                    android:tint="#FFFFFF"
                    android:background="@drawable/icon_btn_bg_dark"
                    android:padding="9dp"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Property preview strip -->
        <LinearLayout
            android:id="@+id/llPropertyStrip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/property_strip_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginTop="10dp">

            <ImageView
                android:id="@+id/ivStripImage"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/property_1"
                android:scaleType="centerCrop"
                android:background="@drawable/photo_slot_filled"
                android:layout_marginEnd="10dp"/>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tvStripTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="The Glass Pavilion" android:textColor="#FFFFFF"
                    android:textSize="13sp" android:fontFamily="@font/montserrat_semibold"/>
                <TextView android:id="@+id/tvStripPrice"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="$3,450,000" android:textColor="#3DB8A8"
                    android:textSize="12sp" android:fontFamily="@font/playfair_display_bold"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ─── Messages RecyclerView ─── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@+id/chatTopBar"
        app:layout_constraintBottom_toTopOf="@+id/inputBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ─── Input bar ─── -->
    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="24dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Attachment -->
        <ImageView
            android:id="@+id/btnAttach"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_attach"
            android:tint="#9BAABB"
            android:padding="6dp"
            android:layout_marginEnd="6dp"/>

        <!-- Text field -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            app:cardCornerRadius="23dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F4F6F8"
            android:layout_marginEnd="8dp">

            <EditText
                android:id="@+id/etChatMessage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="Message…"
                android:textColorHint="#AABBCC"
                android:textColor="#0D1B2A"
                android:textSize="14sp"
                android:fontFamily="@font/montserrat_regular"
                android:background="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:maxLines="4"
                android:inputType="textMultiLine"
                android:gravity="center_vertical"/>
        </androidx.cardview.widget.CardView>

        <!-- Send -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnSendMsg"
            android:layout_width="46dp"
            android:layout_height="46dp"
            app:cardCornerRadius="23dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#0D1B2A">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_send"
                android:tint="#FFFFFF"
                android:layout_gravity="center"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>