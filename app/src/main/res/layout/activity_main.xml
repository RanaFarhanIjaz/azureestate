<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <!-- Fragment Container -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavBar"/>

    <!-- Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabUpload"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_add"
        android:tint="#FFFFFF"
        app:backgroundTint="@color/teal_primary"
        app:elevation="6dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="72dp"
        android:visibility="visible"/>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="@drawable/bottom_nav_bg"
        android:elevation="10dp"
        android:weightSum="6">

        <!-- Discover (Home) -->
        <LinearLayout
            android:id="@+id/navDiscover"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/ivNavDiscover"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_discover"
                android:tint="#3DB8A8"/>

            <TextView
                android:id="@+id/tvNavDiscover"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="#3DB8A8"
                android:textSize="10sp"
                android:fontFamily="@font/montserrat_semibold"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Favorites -->
        <LinearLayout
            android:id="@+id/navFavorites"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/ivNavFavorites"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_favorite"
                android:tint="#9BAABB"/>

            <TextView
                android:id="@+id/tvNavFavorites"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Favorites"
                android:textColor="#9BAABB"
                android:textSize="10sp"
                android:fontFamily="@font/montserrat_regular"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Search -->
        <LinearLayout
            android:id="@+id/navSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/ivNavSearch"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_search"
                android:tint="#9BAABB"/>

            <TextView
                android:id="@+id/tvNavSearch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search"
                android:textColor="#9BAABB"
                android:textSize="10sp"
                android:fontFamily="@font/montserrat_regular"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Messages -->
        <LinearLayout
            android:id="@+id/navMessages"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/ivNavMessages"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_message"
                android:tint="#9BAABB"/>

            <TextView
                android:id="@+id/tvNavMessages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inbox"
                android:textColor="#9BAABB"
                android:textSize="10sp"
                android:fontFamily="@font/montserrat_regular"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- AI Chat -->
        <LinearLayout
            android:id="@+id/navAiChat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/ivNavAiChat"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_chat"
                android:tint="#9BAABB"/>

            <TextView
                android:id="@+id/tvNavAiChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Chat"
                android:textColor="#9BAABB"
                android:textSize="10sp"
                android:fontFamily="@font/montserrat_regular"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/ivNavProfile"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_profile"
                android:tint="#9BAABB"/>

            <TextView
                android:id="@+id/tvNavProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="#9BAABB"
                android:textSize="10sp"
                android:fontFamily="@font/montserrat_regular"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>