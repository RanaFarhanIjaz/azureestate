<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_bg">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@drawable/drag_handle"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="120dp">

            <!-- Header row -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="10dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Filter &amp; Sort"
                    android:textColor="#0D1B2A"
                    android:textSize="20sp"
                    android:fontFamily="@font/playfair_display_bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:id="@+id/tvResetAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reset All"
                    android:textColor="#3DB8A8"
                    android:textSize="13sp"
                    android:fontFamily="@font/montserrat_semibold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ─── Category ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textColor="#0D1B2A"
                android:textSize="15sp"
                android:fontFamily="@font/montserrat_semibold"
                android:layout_marginBottom="12dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:id="@+id/llCategoryChips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/chipAll"
                        android:layout_width="wrap_content" android:layout_height="42dp"
                        android:text="All Properties" android:gravity="center"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textSize="13sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_inactive" android:textColor="#7A8899"
                        android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/chipVilla"
                        android:layout_width="wrap_content" android:layout_height="42dp"
                        android:text="Villa" android:gravity="center"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textSize="13sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_inactive" android:textColor="#7A8899"
                        android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/chipApartment"
                        android:layout_width="wrap_content" android:layout_height="42dp"
                        android:text="Apartment" android:gravity="center"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textSize="13sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_filter_active" android:textColor="#FFFFFF"
                        android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/chipHouse"
                        android:layout_width="wrap_content" android:layout_height="42dp"
                        android:text="House" android:gravity="center"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textSize="13sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_inactive" android:textColor="#7A8899"
                        android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/chipCondo"
                        android:layout_width="wrap_content" android:layout_height="42dp"
                        android:text="Condo" android:gravity="center"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textSize="13sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_inactive" android:textColor="#7A8899"/>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- ─── Price Range ─── -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Price"
                    android:textColor="#0D1B2A"
                    android:textSize="15sp"
                    android:fontFamily="@font/montserrat_semibold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:id="@+id/tvPriceRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$250,000 – $3,500,000"
                    android:textColor="#0D1B2A"
                    android:textSize="13sp"
                    android:fontFamily="@font/montserrat_semibold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.google.android.material.slider.RangeSlider
                android:id="@+id/sliderPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="100000"
                android:valueTo="20000000"
                app:values="@array/default_price_range"
                app:thumbColor="#0D1B2A"
                app:thumbRadius="10dp"
                app:trackColorActive="#3DB8A8"
                app:trackColorInactive="#E0E8F0"
                app:trackHeight="4dp"
                android:layout_marginBottom="24dp"/>

            <!-- ─── Sort ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sort"
                android:textColor="#0D1B2A"
                android:textSize="15sp"
                android:fontFamily="@font/montserrat_semibold"
                android:layout_marginBottom="12dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:id="@+id/llSortChips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/sortNewest"
                        android:layout_width="wrap_content" android:layout_height="42dp"
                        android:text="Newest" android:gravity="center"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textSize="13sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_inactive" android:textColor="#7A8899"
                        android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/sortRecommended"
                        android:layout_width="wrap_content" android:layout_height="42dp"
                        android:text="Recommended" android:gravity="center"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textSize="13sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_filter_active" android:textColor="#FFFFFF"
                        android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/sortHighPrice"
                        android:layout_width="wrap_content" android:layout_height="42dp"
                        android:text="Highest Price" android:gravity="center"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textSize="13sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_inactive" android:textColor="#7A8899"
                        android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/sortLowPrice"
                        android:layout_width="wrap_content" android:layout_height="42dp"
                        android:text="Lowest Price" android:gravity="center"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textSize="13sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_inactive" android:textColor="#7A8899"
                        android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/sortRating"
                        android:layout_width="wrap_content" android:layout_height="42dp"
                        android:text="Top Rated" android:gravity="center"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textSize="13sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_inactive" android:textColor="#7A8899"/>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- ─── Living Area ─── -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Living Area"
                    android:textColor="#0D1B2A"
                    android:textSize="15sp"
                    android:fontFamily="@font/montserrat_semibold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:id="@+id/tvAreaRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="500 – 10,000 sqft"
                    android:textColor="#0D1B2A"
                    android:textSize="13sp"
                    android:fontFamily="@font/montserrat_semibold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.google.android.material.slider.RangeSlider
                android:id="@+id/sliderArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="500"
                android:valueTo="15000"
                app:values="@array/default_area_range"
                app:thumbColor="#0D1B2A"
                app:thumbRadius="10dp"
                app:trackColorActive="#3DB8A8"
                app:trackColorInactive="#E0E8F0"
                app:trackHeight="4dp"
                android:layout_marginBottom="24dp"/>

            <!-- ─── Bedrooms ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bedrooms"
                android:textColor="#0D1B2A"
                android:textSize="15sp"
                android:fontFamily="@font/montserrat_semibold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/llBedroomChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView android:id="@+id/bedAny"
                    android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:text="Any" android:gravity="center"
                    android:textSize="13sp" android:fontFamily="@font/montserrat_medium"
                    android:background="@drawable/chip_filter_active" android:textColor="#FFFFFF"
                    android:layout_marginEnd="6dp"/>
                <TextView android:id="@+id/bed1"
                    android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:text="1+" android:gravity="center"
                    android:textSize="13sp" android:fontFamily="@font/montserrat_medium"
                    android:background="@drawable/chip_inactive" android:textColor="#7A8899"
                    android:layout_marginEnd="6dp"/>
                <TextView android:id="@+id/bed2"
                    android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:text="2+" android:gravity="center"
                    android:textSize="13sp" android:fontFamily="@font/montserrat_medium"
                    android:background="@drawable/chip_inactive" android:textColor="#7A8899"
                    android:layout_marginEnd="6dp"/>
                <TextView android:id="@+id/bed3"
                    android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:text="3+" android:gravity="center"
                    android:textSize="13sp" android:fontFamily="@font/montserrat_medium"
                    android:background="@drawable/chip_inactive" android:textColor="#7A8899"
                    android:layout_marginEnd="6dp"/>
                <TextView android:id="@+id/bed4"
                    android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:text="4+" android:gravity="center"
                    android:textSize="13sp" android:fontFamily="@font/montserrat_medium"
                    android:background="@drawable/chip_inactive" android:textColor="#7A8899"/>
            </LinearLayout>

            <!-- ─── Facilities ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Facilities"
                android:textColor="#0D1B2A"
                android:textSize="15sp"
                android:fontFamily="@font/montserrat_semibold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/llFacilityChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView android:id="@+id/facPool"
                        android:layout_width="0dp" android:layout_height="42dp"
                        android:layout_weight="1" android:text="Pool" android:gravity="center"
                        android:textSize="12sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_inactive" android:textColor="#7A8899"
                        android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/facGym"
                        android:layout_width="0dp" android:layout_height="42dp"
                        android:layout_weight="1" android:text="Gym" android:gravity="center"
                        android:textSize="12sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_inactive" android:textColor="#7A8899"
                        android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/facGarage"
                        android:layout_width="0dp" android:layout_height="42dp"
                        android:layout_weight="1" android:text="Garage" android:gravity="center"
                        android:textSize="12sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_inactive" android:textColor="#7A8899"/>
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <TextView android:id="@+id/facSecurity"
                        android:layout_width="0dp" android:layout_height="42dp"
                        android:layout_weight="1" android:text="Security" android:gravity="center"
                        android:textSize="12sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_inactive" android:textColor="#7A8899"
                        android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/facGarden"
                        android:layout_width="0dp" android:layout_height="42dp"
                        android:layout_weight="1" android:text="Garden" android:gravity="center"
                        android:textSize="12sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_inactive" android:textColor="#7A8899"
                        android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/facCinema"
                        android:layout_width="0dp" android:layout_height="42dp"
                        android:layout_weight="1" android:text="Cinema" android:gravity="center"
                        android:textSize="12sp" android:fontFamily="@font/montserrat_medium"
                        android:background="@drawable/chip_inactive" android:textColor="#7A8899"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ─── Sticky Apply button ─── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="8dp"
        android:weightSum="3">

        <Button
            android:id="@+id/btnResetFilter"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Reset"
            android:textColor="#0D1B2A"
            android:textSize="14sp"
            android:fontFamily="@font/montserrat_semibold"
            android:background="@drawable/btn_outline_dark"
            android:layout_marginEnd="10dp"/>

        <Button
            android:id="@+id/btnApplyFilter"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="2"
            android:text="Show Results"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/montserrat_semibold"
            android:background="@drawable/btn_sign_in"/>
    </LinearLayout>

</LinearLayout>