<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1929"
    android:padding="16dp">

    <!-- ─── Header ─── -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/tvMessagesTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Messages"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:fontFamily="@font/montserrat_bold"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"/>

        <TextView
            android:id="@+id/tvInboxUnreadCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_toEndOf="@id/tvMessagesTitle"
            android:layout_centerVertical="true"
            android:fontFamily="@font/montserrat_medium"
            android:text="All read"
            android:textColor="#5A7A99"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/ivSettings"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_settings"
            android:tint="#FFFFFF"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>

    <!-- ─── Search Bar ─── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">

        <!-- Search bar inside messages -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:background="@drawable/search_bar_dark"
            android:layout_marginTop="14dp">

            <ImageView
                android:id="@+id/ivSearchInboxIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_search"
                android:tint="#5A7A99"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <EditText
                android:id="@+id/etSearchConversations"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:hint="Search conversations..."
                android:textColorHint="#3A5570"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/montserrat_regular"
                android:background="@null"
                android:paddingStart="10dp"
                android:singleLine="true"
                android:inputType="text"
                app:layout_constraintStart_toEndOf="@id/ivSearchInboxIcon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ─── Conversations List ─── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvConversations"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="8dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

        <!-- Empty state if no messages -->
        <LinearLayout
            android:id="@+id/llInboxEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_messages_empty"
                android:tint="#1E3A5F"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No messages yet"
                android:textColor="#3A5570"
                android:textSize="16sp"
                android:fontFamily="@font/montserrat_medium"
                android:layout_marginTop="12dp"/>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
