<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F8"
    android:overScrollMode="never"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="90dp">

        <!-- ═══════════════════════════════════════════ -->
        <!--  HERO HEADER — dark navy gradient           -->
        <!-- ═══════════════════════════════════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/profile_hero_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="52dp"
                android:paddingBottom="36dp">

                <!-- Top row: title only -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Profile"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:fontFamily="@font/playfair_display_bold"
                    android:layout_marginBottom="28dp"/>

                <!-- Avatar + info row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Avatar (no edit badge) -->
                    <ImageView
                        android:id="@+id/ivProfileImage"
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        android:layout_marginEnd="18dp"
                        android:src="@drawable/ic_avatar_placeholder"
                        android:scaleType="centerCrop"
                        android:background="@drawable/profile_avatar_ring"/>

                    <!-- Name, email, membership badge -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvFullName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your Name"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:fontFamily="@font/playfair_display_bold"
                            android:layout_marginBottom="3dp"/>

                        <TextView
                            android:id="@+id/tvEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="email@example.com"
                            android:textColor="#8AAFC8"
                            android:textSize="12sp"
                            android:fontFamily="@font/montserrat_regular"
                            android:layout_marginBottom="10dp"/>

                        <!-- Membership pill -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✦  ESTATE MEMBER"
                            android:textColor="#0D1B2A"
                            android:textSize="9sp"
                            android:fontFamily="@font/montserrat_bold"
                            android:letterSpacing="0.08"
                            android:background="@drawable/membership_badge_bg"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </FrameLayout>

        <!-- ═══════════════════════════════════════════ -->
        <!--  ACTIVITY SECTION                          -->
        <!-- ═══════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Activity"
            android:textColor="#0D1B2A"
            android:textSize="15sp"
            android:fontFamily="@font/montserrat_semibold"
            android:layout_marginStart="20dp"
            android:layout_marginTop="26dp"
            android:layout_marginBottom="10dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <!-- My Properties -->
                <include layout="@layout/item_profile_row"
                    android:id="@+id/rowMyProperties"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F4F6F8" android:layout_marginStart="58dp"/>

                <!-- Wishlist / Favorites -->
                <include layout="@layout/item_profile_row"
                    android:id="@+id/rowWishlist"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F4F6F8" android:layout_marginStart="58dp"/>

                <!-- Messages -->
                <include layout="@layout/item_profile_row"
                    android:id="@+id/rowMessages"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════ -->
        <!--  LEGAL & INFO SECTION                      -->
        <!-- ═══════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Legal &amp; Info"
            android:textColor="#0D1B2A"
            android:textSize="15sp"
            android:fontFamily="@font/montserrat_semibold"
            android:layout_marginStart="20dp"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="10dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <include layout="@layout/item_profile_row"
                    android:id="@+id/rowPrivacy"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F4F6F8" android:layout_marginStart="58dp"/>

                <include layout="@layout/item_profile_row"
                    android:id="@+id/rowTerms"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F4F6F8" android:layout_marginStart="58dp"/>

                <include layout="@layout/item_profile_row"
                    android:id="@+id/rowHelp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F4F6F8" android:layout_marginStart="58dp"/>

                <include layout="@layout/item_profile_row"
                    android:id="@+id/rowAbout"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════ -->
        <!--  SIGN OUT                                  -->
        <!-- ═══════════════════════════════════════════ -->
        <Button
            android:id="@+id/btnSignOut"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Sign Out"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="#E53935"
            android:fontFamily="@font/montserrat_semibold"
            android:background="@drawable/btn_signout"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginTop="24dp"/>

        <!-- Version tag -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Azure Estate"
                android:textColor="#AABBCC"
                android:textSize="11sp"
                android:fontFamily="@font/playfair_display_bold"
                android:letterSpacing="0.04"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Version 1.0.0  ·  © 2025"
                android:textColor="#C8D4E0"
                android:textSize="10sp"
                android:fontFamily="@font/montserrat_regular"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>