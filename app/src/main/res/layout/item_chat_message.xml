<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <!-- USER message (right aligned) -->
    <LinearLayout
        android:id="@+id/llUserBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:maxWidth="260dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvUserMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bubble_user"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/montserrat_regular"
            android:lineSpacingMultiplier="1.4"/>

        <TextView
            android:id="@+id/tvUserTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:textColor="#9BAABB"
            android:textSize="10sp"
            android:fontFamily="@font/montserrat_regular"
            android:layout_marginTop="3dp"
            android:layout_marginEnd="2dp"/>
    </LinearLayout>

    <!-- AI message (left aligned) -->
    <LinearLayout
        android:id="@+id/llAiBubble"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top"
        android:visibility="gone">

        <!-- AI avatar dot -->
        <FrameLayout
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="2dp">
            <View
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/ai_avatar_small_bg"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:fontFamily="@font/montserrat_bold"
                android:layout_gravity="center"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAiMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="260dp"
                android:background="@drawable/bubble_ai"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:textColor="#0D1B2A"
                android:textSize="13sp"
                android:fontFamily="@font/montserrat_regular"
                android:lineSpacingMultiplier="1.5"/>

            <TextView
                android:id="@+id/tvAiTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#9BAABB"
                android:textSize="10sp"
                android:fontFamily="@font/montserrat_regular"
                android:layout_marginTop="3dp"
                android:layout_marginStart="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Typing indicator (3 animated dots) -->
    <LinearLayout
        android:id="@+id/llTypingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="8dp">
            <View android:layout_width="30dp" android:layout_height="30dp"
                android:background="@drawable/ai_avatar_small_bg"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AI" android:textColor="#FFFFFF" android:textSize="9sp"
                android:fontFamily="@font/montserrat_bold" android:layout_gravity="center"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="60dp"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bubble_ai">

            <View android:id="@+id/dot1" android:layout_width="7dp" android:layout_height="7dp"
                android:background="@drawable/typing_dot" android:layout_marginEnd="4dp"/>
            <View android:id="@+id/dot2" android:layout_width="7dp" android:layout_height="7dp"
                android:background="@drawable/typing_dot" android:layout_marginEnd="4dp"/>
            <View android:id="@+id/dot3" android:layout_width="7dp" android:layout_height="7dp"
                android:background="@drawable/typing_dot"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>