<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="78dp"
    android:background="#FFFFFF"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:foreground="?attr/selectableItemBackground">

    <!-- Avatar -->
    <FrameLayout
        android:id="@+id/avatarFrame"
        android:layout_width="50dp"
        android:layout_height="50dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/ivConvAvatar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_avatar_placeholder"
            android:scaleType="centerCrop"
            android:background="@drawable/profile_avatar_ring"/>

        <!-- Online dot -->
        <View
            android:id="@+id/ivConvOnline"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/status_dot_online"
            android:layout_gravity="bottom|end"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Property thumbnail -->
    <ImageView
        android:id="@+id/ivConvPropertyThumb"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/property_1"
        android:scaleType="centerCrop"
        android:background="@drawable/photo_slot_filled"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toEndOf="@+id/avatarFrame"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Text block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toEndOf="@+id/ivConvPropertyThumb"
        app:layout_constraintEnd_toStartOf="@+id/llConvMeta"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Other user name -->
        <TextView
            android:id="@+id/tvConvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Elena Rodriguez"
            android:textColor="#0D1B2A"
            android:textSize="14sp"
            android:fontFamily="@font/montserrat_semibold"
            android:layout_marginBottom="2dp"/>

        <!-- Property name -->
        <TextView
            android:id="@+id/tvConvPropertyName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="The Glass Pavilion"
            android:textColor="#3DB8A8"
            android:textSize="11sp"
            android:fontFamily="@font/montserrat_medium"
            android:layout_marginBottom="3dp"/>

        <!-- Last message preview -->
        <TextView
            android:id="@+id/tvConvLastMsg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="I'd be happy to schedule a tour for you..."
            android:textColor="#7A8899"
            android:textSize="12sp"
            android:fontFamily="@font/montserrat_regular"
            android:maxLines="1"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Right meta: time + unread badge -->
    <LinearLayout
        android:id="@+id/llConvMeta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvConvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2:45 PM"
            android:textColor="#9BAABB"
            android:textSize="11sp"
            android:fontFamily="@font/montserrat_regular"
            android:layout_marginBottom="6dp"/>

        <!-- Unread count badge -->
        <TextView
            android:id="@+id/tvConvUnread"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:text="2"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:fontFamily="@font/montserrat_bold"
            android:gravity="center"
            android:background="@drawable/badge_teal_dot"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Bottom divider -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#F4F6F8"
        android:layout_marginStart="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>