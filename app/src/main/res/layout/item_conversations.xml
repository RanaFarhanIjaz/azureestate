<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- ── Avatar with online dot ── -->
        <FrameLayout
            android:id="@+id/avatarFrame"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivConvAvatar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_avatar_placeholder"
                android:scaleType="centerCrop"
                android:background="@drawable/profile_avatar_ring"/>

            <!-- Online dot -->
            <View
                android:id="@+id/ivConvOnline"
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:background="@drawable/status_dot_online"
                android:layout_gravity="bottom|end"
                android:visibility="gone"/>
        </FrameLayout>

        <!-- ── Text block ── -->
        <LinearLayout
            android:id="@+id/textBlock"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintStart_toEndOf="@+id/avatarFrame"
            app:layout_constraintEnd_toStartOf="@+id/llConvMeta"
            app:layout_constraintTop_toTopOf="@+id/avatarFrame"
            app:layout_constraintBottom_toBottomOf="@+id/avatarFrame">

            <!-- Other user name -->
            <TextView
                android:id="@+id/tvConvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User"
                android:textColor="#0D1B2A"
                android:textSize="15sp"
                android:fontFamily="@font/montserrat_semibold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Property name -->
            <TextView
                android:id="@+id/tvConvPropertyName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Property"
                android:textColor="#3DB8A8"
                android:textSize="11sp"
                android:fontFamily="@font/montserrat_medium"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="1dp"/>

            <!-- Last message preview -->
            <TextView
                android:id="@+id/tvConvLastMsg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Message preview…"
                android:textColor="#8A99AA"
                android:textSize="12sp"
                android:fontFamily="@font/montserrat_regular"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- ── Right meta: time + unread badge ── -->
        <LinearLayout
            android:id="@+id/llConvMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end|center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/avatarFrame"
            app:layout_constraintBottom_toBottomOf="@+id/avatarFrame">

            <TextView
                android:id="@+id/tvConvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#B0BFCC"
                android:textSize="11sp"
                android:fontFamily="@font/montserrat_regular"
                android:layout_marginBottom="6dp"/>

            <!-- Unread badge -->
            <TextView
                android:id="@+id/tvConvUnread"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:background="@drawable/badge_teal_dot"
                android:visibility="gone"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>