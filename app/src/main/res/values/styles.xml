<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- App base theme -->
    <style name="Theme.AzureEstate" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/teal_primary</item>
        <item name="colorPrimaryDark">@color/navy_dark</item>
        <item name="colorAccent">@color/teal_light</item>
        <item name="android:windowBackground">@color/bg_page</item>
        <item name="android:statusBarColor">@color/navy_medium</item>
    </style>

    <style name="BottomSheetDialogTheme"
        parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/AzureBottomSheet</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="AzureBottomSheet"
        parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.AzureBottomSheet</item>
    </style>

    <style name="ShapeAppearance.AzureBottomSheet"
        parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
    </style>

    <!-- Splash theme: full screen dark -->
    <style name="Theme.AzureEstate.Splash" parent="Theme.AzureEstate">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/navy_medium</item>
        <item name="android:navigationBarColor">@color/navy_medium</item>
    </style>

    <!-- TextInputLayout: borderless rounded style -->
    <style name="AzureInputLayout"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="boxStrokeColor">@color/transparent</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/text_hint</item>
    </style>


    <!-- Field label text style -->
    <style name="FieldLabel">
        <item name="android:textColor">#7A8899</item>
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">@font/montserrat_semibold</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- DatePicker theme to match brand -->
    <style name="DatePickerTheme" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="colorPrimary">#3DB8A8</item>
        <item name="colorPrimaryDark">#0D1B2A</item>
        <item name="colorAccent">#3DB8A8</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
    </style>
</resources>